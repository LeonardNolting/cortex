{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cortex",
  "version": "0.8.0",
  "identifier": "com.leonardnolting.cortex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cortex",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LeonardNolting/cortex/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGRjk4NUNBODZCMTMyMUMKUldRY01yR0d5b1g1ajk3N1BwSUgzR3N4Qk44WXEycHNLUytxWTZQcy9xaGdOckRnUUZ1NHpPSnQK"
    }
  }
}

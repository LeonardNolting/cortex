{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cortex",
  "version": "0.1.0",
  "identifier": "com.leonardnolting.cortex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cortex",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LeonardNolting/cortex/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2MTZFQ0UwNTExMUY0QzUKUldURjlCRlI0T3dXMXY2bmtlWVczNHNhOEVXSTIrOWRzeGtTbkJXTHk5YjlMMmFmR2ozZmhzdjQK"
    }
  }
}

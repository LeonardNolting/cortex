{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "/**"
        }
      ]
    },
    "opener:allow-open-url",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "sql:default",
    "fs:default",
    "fs:allow-write",
    "fs:allow-read",
    "fs:allow-exists",
    "core:path:default",
    "fs:allow-document-write-recursive",
    "fs:allow-document-read-recursive",
    "process:default",
    "dialog:default"
  ]
}